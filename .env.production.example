# =============================================================================
# DevFlow — WhatsApp Platform (App Raiz)
# .env.production.example — Template para deploy em produção
# =============================================================================
# 
# IMPORTANTE:
# - Copie para .env.production e preencha com valores reais
# - NUNCA commitar .env.production (já está no .gitignore)
# - Use secrets do Vercel/hosting para variáveis sensíveis
# - Rotacione chaves se houve exposição
#
# =============================================================================

# ========================
# GLOBAL
# ========================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://devflowlabs.com.br
NEXT_PUBLIC_WHATSAPP_APP_URL=https://devflowlabs.com.br

# ========================
# DATABASE (WHATSAPP)
# ========================
# PostgreSQL dedicado para WhatsApp Platform
# Schema: prisma/whatsapp.schema.prisma
# Tabelas: WhatsappPhoneNumber, Tenant, WaInboxThread, BillingSubscription, etc.
#
# IMPORTANTE — Pooler (Supabase/Neon/Vercel Postgres):
# Se usar URL de pooler (porta 6543 no Supabase, etc.), adicione ?pgbouncer=true
# para evitar erro "prepared statement s0 already exists" em serverless.
# Exemplo Supabase: ...pooler.supabase.com:6543/postgres?pgbouncer=true
WHATSAPP_DATABASE_URL=postgresql://user:password@host:5432/whatsapp_db
WHATSAPP_DIRECT_URL=postgresql://user:password@host:5432/whatsapp_db

# ========================
# AUTH (DASHBOARD)
# ========================
# JWT para autenticação do dashboard /dashboard/whatsapp
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Cookie domain (opcional, para cross-subdomain)
COOKIE_DOMAIN=.devflowlabs.com.br

# ========================
# WHATSAPP CLOUD API (Meta)
# ========================
# Credenciais da Meta Cloud API
# Fallback single-tenant (se não usar multi-tenant via Embedded Signup)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# Business Account ID (opcional)
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Demo mode (desativar em produção)
WHATSAPP_DEMO_MODE=false

# ========================
# META EMBEDDED SIGNUP
# ========================
# OAuth para conectar números via dashboard
# Meta Business Suite → WhatsApp Manager → Embedded Signup → Config ID
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=

# API Version (padrão: v21.0)
META_API_VERSION=v21.0

# ========================
# SUPABASE (CONVERSAS / MESSAGES)
# ========================
# Opcional: usado para conversations, messages, webhook_logs
# Se não configurado, o app funciona sem persistência de conversas
WHATSAPP_SUPABASE_URL=
WHATSAPP_SUPABASE_SERVICE_ROLE_KEY=

# ========================
# STRIPE (BILLING)
# ========================
# IMPORTANTE: Duas camadas de cobrança
# 1. PLANOS FIXOS (recorrentes): Starter, Pro, Scale
# 2. OVERAGE (metered): mensagens e IA além do plano

# --- Stripe LIVE (produção) ---
WHATSAPP_STRIPE_SECRET_KEY=sk_live_...
WHATSAPP_STRIPE_WEBHOOK_SECRET=whsec_...

# Planos fixos (preços recorrentes)
WHATSAPP_STRIPE_PRICE_STARTER=price_1TD4h2DCRYOE69AQ4QmjzrGM
WHATSAPP_STRIPE_PRICE_PRO=price_1TD4itDCRYOE69AQd1oaiV8F
WHATSAPP_STRIPE_PRICE_SCALE=price_1TD4kTDCRYOE69AQYP8pKaiz

# Overage — Mensagens (meter event: whatsapp_messages)
WHATSAPP_STRIPE_METERED_PRODUCT_MESSAGES=prod_UBRusheWCSbgNs
WHATSAPP_STRIPE_METERED_PRICE_MESSAGES=price_1TD50YDCRYOE69AQUi5x3TFf

# Overage — IA (meter event: ai_usage)
WHATSAPP_STRIPE_METERED_PRODUCT_AI=prod_UBRxA6RCPfFmTr
WHATSAPP_STRIPE_METERED_PRICE_AI=price_1TD540DCRYOE69AQnSbivxDS

# ========================
# BILLING (ENFORCEMENT)
# ========================
# Ativar bloqueio de uso quando exceder limites do plano
# true = bloqueia (hard limit)
# false = permite mas registra overage (soft limit)
BILLING_ENFORCE_LIMITS=true

# Preços unitários em BRL (para cálculo de overage)
BILLING_PRICE_MESSAGE_BRL=0.03
BILLING_PRICE_AI_BRL=0.09

# ========================
# ADMIN / MÉTRICAS (OPCIONAL)
# ========================
# Secret para rotas de admin/métricas (se houver)
WHATSAPP_ADMIN_METRICS_SECRET=

# ========================
# IA (OPCIONAL)
# ========================
# Para respostas automáticas via IA
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# NOTAS DE DEPLOY
# =============================================================================
#
# 1. WEBHOOK URL (Meta):
#    https://devflowlabs.com.br/api/webhook/whatsapp
#
# 2. OAUTH REDIRECT URI (Meta Embedded Signup):
#    https://devflowlabs.com.br/dashboard/whatsapp/callback
#
# 3. STRIPE WEBHOOK URL:
#    https://devflowlabs.com.br/api/billing/webhook
#    (ou rota específica do billing, se diferente)
#
# 4. MIGRATIONS:
#    pnpm db:migrate:deploy (ou equivalente no seu deploy)
#    Garante que o banco tenha as tabelas do prisma/whatsapp.schema.prisma
#
# 5. FALLBACKS:
#    Alguns módulos aceitam variáveis sem prefixo WHATSAPP_ como fallback.
#    Ex.: STRIPE_SECRET_KEY se WHATSAPP_STRIPE_SECRET_KEY ausente.
#    Em produção, prefira usar apenas o namespace WHATSAPP_*.
#
# =============================================================================
