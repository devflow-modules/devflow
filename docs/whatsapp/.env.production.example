# WhatsApp Platform — variáveis para produção (Release Candidate)
# Copiar para o ambiente (Vercel, Railway, .env do servidor) e preencher.
# Webhook-api e platform podem usar o mesmo banco; cada app tem suas próprias vars.

# ========== Banco (compartilhado pelos dois apps) ==========
# Pooler para runtime (Vercel/serverless); conexão direta para migrations
WHATSAPP_DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
WHATSAPP_DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ========== whatsapp-webhook-api ==========
PORT=3005
WHATSAPP_VERIFY_TOKEN="seu_token_meta_webhook"
# Single-tenant (opcional): se não usar multi-tenant por phone_number_id
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_DISPLAY_PHONE_NUMBER=

# LLM (opcional)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ========== whatsapp-platform (Next.js) ==========
JWT_SECRET="minimo-32-caracteres-aleatorios-seguros"
NEXT_PUBLIC_WHATSAPP_APP_URL="https://wa.seudominio.com"

# Supabase (painel: filas, agentes, conversas)
WHATSAPP_SUPABASE_URL="https://[PROJECT].supabase.co"
WHATSAPP_SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Admin / métricas em produção
WHATSAPP_ADMIN_METRICS_SECRET="cookie-ou-header-secreto-metricas"

# Stripe (billing) — namespace WHATSAPP_* para isolamento
WHATSAPP_STRIPE_SECRET_KEY=sk_live_...
WHATSAPP_STRIPE_WEBHOOK_SECRET=whsec_...
WHATSAPP_STRIPE_PRICE_PRO=price_...
WHATSAPP_STRIPE_PRICE_SCALE=price_...

# ========== Smoke test (CI/staging) ==========
# PLATFORM_URL=http://localhost:3000
