{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@devflow/ui": ["./packages/ui/src"],
      "@devflow/billing-core": ["./packages/billing-core/src"],
      "@devflow/analytics-core": ["./packages/analytics-core/src"],
      "@devflow/auth-core": ["./packages/auth-core/src"],
      "@devflow/supabase-utils": ["./packages/supabase-utils/src"],
      "@devflow/testing-utils": ["./packages/testing-utils/src"],
      "@devflow/config": ["./packages/config"],
      "@devflow/whatsapp-core": ["./packages/whatsapp-core/src"],
      "@devflow/ai-core": ["./packages/ai-core/src"],
      "@wa/*": ["./apps/whatsapp-platform/src/*"],
      "@/modules/whatsapp/*": ["./apps/whatsapp-platform/src/modules/whatsapp/*"],
      "@/modules/whatsapp-legacy/*": ["./src/modules/whatsapp/*"],
      "@/modules/messaging/*": ["./apps/whatsapp-platform/src/modules/messaging/*"],
      "@/modules/inbox": ["./apps/whatsapp-platform/src/modules/inbox"],
      "@/modules/inbox/*": ["./apps/whatsapp-platform/src/modules/inbox/*"],
      "@/modules/ai/aiUsageService": ["./src/modules/ai/aiUsageService"],
      "@/modules/ai/*": ["./apps/whatsapp-platform/src/modules/ai/*"],
      "@/modules/analytics": ["./apps/whatsapp-platform/src/modules/analytics"],
      "@/modules/analytics/*": ["./apps/whatsapp-platform/src/modules/analytics/*"],
      "@/modules/auth/*": ["./apps/whatsapp-platform/src/modules/auth/*"],
      "@/modules/tenants": ["./apps/whatsapp-platform/src/modules/tenants"],
      "@/modules/tenants/*": ["./apps/whatsapp-platform/src/modules/tenants/*"],
      "@/modules/conversations/*": ["./apps/whatsapp-platform/src/modules/conversations/*"],
      "@/modules/realtime/*": ["./apps/whatsapp-platform/src/modules/realtime/*"],
      "@/modules/automation": ["./apps/whatsapp-platform/src/modules/automation"],
      "@/modules/automation/*": ["./apps/whatsapp-platform/src/modules/automation/*"],
      "@/modules/stripe": ["./apps/whatsapp-platform/src/modules/stripe"],
      "@/modules/stripe/*": ["./apps/whatsapp-platform/src/modules/stripe/*"],
      "@/modules/billing/usageService": ["./apps/whatsapp-platform/src/modules/billing/usageService"],
      "@/modules/billing/usage.service": ["./apps/whatsapp-platform/src/modules/billing/usage.service"],
      "@/modules/billing/enforcementService": ["./apps/whatsapp-platform/src/modules/billing/enforcementService"],
      "@/modules/billing/featureGate": ["./apps/whatsapp-platform/src/modules/billing/featureGate"],
      "@/modules/billing/planCapabilities": ["./apps/whatsapp-platform/src/modules/billing/planCapabilities"],
      "@/modules/billing/planConfig": ["./apps/whatsapp-platform/src/modules/billing/planConfig"],
      "@/modules/billing/billingObserverService": ["./apps/whatsapp-platform/src/modules/billing/billingObserverService"],
      "@/modules/billing/subscriptionService": ["./apps/whatsapp-platform/src/modules/billing/subscriptionService"],
      "@/modules/billing/infrastructure/*": ["./apps/whatsapp-platform/src/modules/billing/infrastructure/*"],
      "@/modules/billing/application/*": ["./apps/whatsapp-platform/src/modules/billing/application/*"],
      "@/modules/billing/BillingService": ["./src/modules/billing/BillingService"],
      "@/modules/billing/BillingPortalService": ["./src/modules/billing/BillingPortalService"],
      "@/modules/billing/BillingProfileRepository": ["./src/modules/billing/BillingProfileRepository"],
      "@/modules/billing/billingAnalytics": ["./src/modules/billing/billingAnalytics"],
      "@/modules/billing/plans": ["./src/modules/billing/plans"],
      "@/modules/billing/billingUiState": ["./src/modules/billing/billingUiState"],
      "@/modules/billing/pricingPresentation": ["./src/modules/billing/pricingPresentation"],
      "@/modules/billing/*": ["./apps/whatsapp-platform/src/modules/billing/*"],
      "@/modules/whatsapp-inbox": ["./src/modules/whatsapp-inbox"],
      "@/modules/whatsapp-inbox/*": ["./src/modules/whatsapp-inbox/*"],
      "@/modules/whatsapp-messaging": ["./src/modules/whatsapp-messaging"],
      "@/modules/whatsapp-messaging/*": ["./src/modules/whatsapp-messaging/*"],
      "@/modules/whatsapp-onboarding": ["./src/modules/whatsapp-onboarding"],
      "@/modules/whatsapp-onboarding/*": ["./src/modules/whatsapp-onboarding/*"],
      "@/lib/db/*": ["./apps/whatsapp-platform/src/lib/db/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/**/*.mts",
    "apps/whatsapp-platform/src/modules/**/*.ts",
    "apps/whatsapp-platform/src/modules/**/*.tsx"
  ],
  "exclude": ["node_modules", "templates", "apps/financeiro", "apps/funklab", "apps/investigamais", "apps/ops", "apps/whatsapp-webhook-api", "apps/whatsapp-platform/src/modules/agents", "apps/whatsapp-platform/src/modules/queues"]
}
