# WhatsApp Webhook API
# Copy to .env and fill values

# Postgres (Prisma) — projeto Supabase dedicado WhatsApp
# DATABASE_URL: pooler (porta 6543) — recomendado para Vercel/serverless
# DIRECT_URL: conexão direta (porta 5432) — usada por prisma migrate deploy
# Senha: Supabase → Project → Settings → Database
WHATSAPP_DATABASE_URL="postgresql://postgres.xhtsgqvdqpfuotctaqow:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres"
WHATSAPP_DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.xhtsgqvdqpfuotctaqow.supabase.co:5432/postgres"

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_DISPLAY_PHONE_NUMBER=+5511999999999

# Optional: LLM (OpenAI or Anthropic) for AIService
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3005
