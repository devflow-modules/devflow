// WhatsApp Webhook API — Tenant, Conversation, Message
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Tenant {
  id                   String         @id @default(cuid())
  name                 String?        @map("name")
  whatsappPhone        String?        @map("whatsapp_phone")   // normalized phone for resolution
  systemPrompt         String?        @map("system_prompt") @db.Text
  businessType         String?        @map("business_type")
  phoneNumberId        String         @unique @map("phone_number_id")
  displayPhoneNumber   String?        @map("display_phone_number")
  accessToken          String         @map("access_token")
  apiKey               String?        @unique @map("api_key")   // for API key resolution
  subdomain            String?        @unique @map("subdomain")  // for subdomain resolution
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  conversations        Conversation[]

  @@map("whatsapp_tenants")
}

model Conversation {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  externalId String   @map("external_id") // e.g. wa_id (phone)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([tenantId, externalId])
  @@map("whatsapp_conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  sender         String   // "user" | "business" or wa_id
  messageType    String   @map("message_type") // text, image, audio, etc.
  content        String   @db.Text
  timestamp      DateTime @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("whatsapp_messages")
}
