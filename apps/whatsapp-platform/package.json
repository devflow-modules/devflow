{
    "name": "@devflow/app-whatsapp-platform",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "node scripts/load-env-and-dev.mjs",
        "build": "NODE_ENV=production prisma generate && next build",
        "db:generate": "prisma generate",
        "db:migrate": "node scripts/load-env-and-migrate.mjs",
        "db:reset-app-data": "node scripts/load-env-and-reset-app-data.mjs",
        "start": "next start --port 3000",
        "lint": "eslint src",
        "check:buttons": "pnpm -w run check:buttons",
        "lint:design-system": "pnpm -w run lint:design-system",
        "test": "vitest run",
        "test:node": "vitest run --project node",
        "test:ui": "vitest run --project ui",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test tests/e2e",
        "test:a11y": "playwright test tests/a11y",
        "test:e2e:inbox": "playwright test tests/e2e/inbox.spec.ts",
        "smoke": "tsx ../../scripts/smoke-test-whatsapp.ts",
        "ops:check-channel": "tsx ../../scripts/ops/check-whatsapp-channel.ts",
        "ops:promote-admin": "tsx scripts/promote-platform-admin.ts",
        "ops:provision-devflow-sales": "tsx scripts/provision-devflow-sales-tenant.ts",
        "test:meter": "tsx scripts/test-meter-usage.ts"
    },
    "dependencies": {
        "@devflow/ai-core": "workspace:*",
        "@devflow/analytics-core": "workspace:*",
        "@devflow/billing-core": "workspace:*",
        "@devflow/ui": "workspace:*",
        "@devflow/whatsapp-core": "workspace:*",
        "@prisma/client": "^6.0.0",
        "@react-email/components": "^1.0.11",
        "@react-email/render": "^2.0.5",
        "@supabase/supabase-js": "^2.49.0",
        "@tanstack/react-query": "^5.91.0",
        "bcryptjs": "^2.4.3",
        "jose": "^6.0.0",
        "next": "16.1.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "recharts": "^2.15.0",
        "resend": "^4.0.0",
        "stripe": "^17.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@playwright/test": "^1.51.0",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/coverage-v8": "^4.1.5",
        "dotenv": "^17.3.1",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "jsdom": "^29.0.0",
        "prisma": "^6.0.0",
        "tailwindcss": "^4",
        "tsx": "^4.19.0",
        "typescript": "^5",
        "vitest": "^4.1.5"
    }
}
