# WhatsApp Platform — variáveis de ambiente
# Copiar para .env.local e preencher.
#
# Produção: validação automática no arranque (instrumentation) — ver docs/ops/ENVIRONMENT.md
# Emergência apenas: SKIP_ENV_VALIDATION=1

# Banco dedicado WhatsApp (Prisma) — mesmo projeto Supabase abaixo
# DATABASE_URL: pooler (6543) — recomendado para Vercel/serverless
# Obrigatório incluir ?pgbouncer=true (ou &pgbouncer=true) no pooler — senão Prisma → Postgres 42P05 "prepared statement already exists".
# DIRECT_URL: conexão direta (5432) — usada por prisma migrate deploy
# Senha: Supabase → Project → Settings → Database
WHATSAPP_DATABASE_URL="postgresql://postgres.xhtsgqvdqpfuotctaqow:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
WHATSAPP_DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.xhtsgqvdqpfuotctaqow.supabase.co:5432/postgres"

# Supabase do projeto WhatsApp (obrigatório para persistência/conversas/agentes)
WHATSAPP_SUPABASE_URL=https://xhtsgqvdqpfuotctaqow.supabase.co
WHATSAPP_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Opcional: cliente público (ex.: realtime)
# WHATSAPP_SUPABASE_ANON_KEY=eyJ...

# WhatsApp Cloud API (obrigatório para webhook e envio)
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao
# Opcional: limite de pedidos POST /api/webhook/whatsapp por IP (defeito: 5000 / 15 min)
# WHATSAPP_WEBHOOK_RATE_MAX=5000
# WHATSAPP_WEBHOOK_RATE_WINDOW_MS=900000
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAx...
# Opcional: número formatado para exibição
WHATSAPP_DISPLAY_PHONE_NUMBER=+5511999999999

# Modo demo: responde "demo" com mensagem especial
WHATSAPP_DEMO_MODE=false

# TTL (ms) dos claims de resposta automática (default 120000). Ver WA_AUTO_REPLY_CLAIM_TTL_MS.
# WA_AUTO_REPLY_CLAIM_TTL_MS=120000

# Desenvolvimento / Playwright: não chamar a Meta ao guardar Phone Number ID no PATCH /api/tenants/me (não usar em produção)
# WHATSAPP_SKIP_CLOUD_CREDENTIAL_VALIDATE=1

# Playwright (test:e2e): credenciais de um utilizador admin de teste
# E2E_WHATSAPP_ADMIN_EMAIL=
# E2E_WHATSAPP_ADMIN_PASSWORD=

# Meta Embedded Signup (multi-tenant — conectar número por cliente)
# App ID e Secret do app Meta for Developers
# Config ID: Meta Business Suite → WhatsApp Manager → Embedded Signup
# META_APP_ID=123456789
# META_APP_SECRET=xxx
# META_EMBEDDED_SIGNUP_CONFIG_ID=123456789

# Auth (obrigatório para signup/login — JWT)
JWT_SECRET=your-secret-min-32-chars

# Resend — obrigatório para «esqueci minha senha» / e-mails transacionais
# https://resend.com — domínio do remetente tem de estar verificado
# RESEND_API_KEY=re_...
# Remetente (preferir EMAIL_FROM; RESEND_FROM ou RESEND_FROM_EMAIL também funcionam)
# EMAIL_FROM=noreply@send.devflowlabs.com.br
# RESEND_FROM=noreply@send.devflowlabs.com.br
# RESEND_FROM_EMAIL=noreply@send.devflowlabs.com.br
# Resposta / Reply-To opcional
# EMAIL_REPLY_TO=suporte@devflowlabs.com.br

# Suporte — destino dos pedidos «Precisa de ajuda?» (POST /api/support/report)
# E-mail interno (usa RESEND_API_KEY + EMAIL_FROM como remetente)
# WHATSAPP_SUPPORT_NOTIFY_EMAIL=suporte@devflowlabs.com.br
# Webhook opcional (Slack/Discord/custom) — JSON { text, payload }
# WHATSAPP_SUPPORT_WEBHOOK_URL=https://hooks.slack.com/services/...
# Opcional: nome na caixa de entrada (default: DevFlow)
# RESEND_FROM_NAME=DevFlow Labs
# Ou já no formato completo:
# EMAIL_FROM="DevFlow Labs <noreply@send.devflowlabs.com.br>"

# URL pública do app (checkout, portal, signup)
NEXT_PUBLIC_WHATSAPP_APP_URL=http://localhost:3000

# Site principal DevFlow (opcional — botão na página inicial do produto)
# NEXT_PUBLIC_DEVFLOW_WEBSITE_URL=https://devflowlabs.com.br

# Admin metrics (produção: protege /admin/metrics e /api/admin/metrics)
# WHATSAPP_ADMIN_METRICS_SECRET=your-admin-secret

# GET /api/ops/metrics — obrigatório em produção; header X-Ops-Metrics-Key (ver apps/ops OPS_WHATSAPP_METRICS_KEY)
# WHATSAPP_OPS_METRICS_SECRET=your-ops-metrics-key

# Stripe - LIVE
# WHATSAPP_STRIPE_SECRET_KEY=sk_live_...
# WHATSAPP_STRIPE_WEBHOOK_SECRET=whsec_...
# WHATSAPP_STRIPE_PRICE_PRO=price_...
# WHATSAPP_STRIPE_PRICE_SCALE=price_...

# Stripe - TEST (dev)
# WHATSAPP_STRIPE_TEST_SECRET_KEY=sk_test_...
# WHATSAPP_STRIPE_TEST_WEBHOOK_SECRET=whsec_...
# WHATSAPP_STRIPE_TEST_PRICE_PRO=price_...
# WHATSAPP_STRIPE_TEST_PRICE_SCALE=price_...

# IA com LLM (opcional) — SERVER-SIDE ONLY (nunca NEXT_PUBLIC_*)
# WHATSAPP_ENABLE_LLM=false
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_MS=10000
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
