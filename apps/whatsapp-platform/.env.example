# WhatsApp Platform — variáveis de ambiente
# Copiar para .env.local e preencher.

# Banco dedicado WhatsApp (Prisma) — mesmo projeto Supabase abaixo
# DATABASE_URL: pooler (6543) — recomendado para Vercel/serverless
# DIRECT_URL: conexão direta (5432) — usada por prisma migrate deploy
# Senha: Supabase → Project → Settings → Database
WHATSAPP_DATABASE_URL="postgresql://postgres.xhtsgqvdqpfuotctaqow:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres"
WHATSAPP_DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.xhtsgqvdqpfuotctaqow.supabase.co:5432/postgres"

# Supabase do projeto WhatsApp (obrigatório para persistência/conversas/agentes)
WHATSAPP_SUPABASE_URL=https://xhtsgqvdqpfuotctaqow.supabase.co
WHATSAPP_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Opcional: cliente público (ex.: realtime)
# WHATSAPP_SUPABASE_ANON_KEY=eyJ...

# WhatsApp Cloud API (obrigatório para webhook e envio)
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAx...
# Opcional: número formatado para exibição
WHATSAPP_DISPLAY_PHONE_NUMBER=+5511999999999

# Modo demo: responde "demo" com mensagem especial
WHATSAPP_DEMO_MODE=false

# Admin metrics (produção: protege /admin/metrics e /api/admin/metrics)
# ADMIN_METRICS_SECRET=your-admin-secret

# IA com LLM (opcional): definir WHATSAPP_ENABLE_LLM=true e uma das chaves abaixo
# WHATSAPP_ENABLE_LLM=false
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
