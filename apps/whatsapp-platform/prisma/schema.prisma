// WhatsApp Platform — dedicated WhatsApp DB (same as whatsapp-webhook-api).
//
// Supabase pooler (ex. *.pooler.supabase.com:6543): WHATSAPP_DATABASE_URL deve incluir
// ?pgbouncer=true (ou &pgbouncer=true) para evitar Postgres 42P05 "prepared statement already exists".
// Migrações: WHATSAPP_DIRECT_URL na instância direta :5432 (sem pooler de transação).
datasource db {
  provider  = "postgresql"
  url       = env("WHATSAPP_DATABASE_URL")
  directUrl = env("WHATSAPP_DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-whatsapp"
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

/** Ciclo comercial GTM: avaliação vs cliente implantado (onboarding / reporting). */
enum TenantGtmLifecycle {
  AVALIACAO
  IMPLANTADO
}

enum WhatsappPhoneNumberStatus {
  /** Canal criado manualmente ou aguardando token; webhook e inbox recebem, envio bloqueado. */
  PENDING_ACTIVATION
  ACTIVE
  ERROR
}

/** Verificação Meta Business (camada operacional admin — não substitui o fluxo Meta). */
enum MetaBusinessVerificationStatus {
  NOT_STARTED
  READY_FOR_SUBMISSION
  IN_REVIEW
  APPROVED
  REJECTED
}

/** Finalidade operacional da linha WhatsApp (MVP multi-canal). */
enum WhatsappChannelPurpose {
  GENERAL
  SUPPORT
  SALES
  PROSPECTING
  FINANCE
}

/// Várias linhas por tenant; `phone_number_id` (Meta) é único globalmente.
/// No máximo uma linha com `is_primary` / `is_default_outbound` por tenant (índices únicos parciais SQL).
model WhatsappPhoneNumber {
  id                  String                   @id @default(cuid())
  tenantId            String                   @map("tenant_id")
  phoneNumberId       String                   @unique @map("phone_number_id")
  displayPhoneNumber  String?                  @map("display_phone_number")
  wabaId              String?                  @map("waba_id")
  accessToken         String?                  @map("access_token")
  businessId          String?                  @map("business_id")
  status              WhatsappPhoneNumberStatus @default(PENDING_ACTIVATION) @map("status")
  isPrimary           Boolean                  @default(false) @map("is_primary")
  isDefaultOutbound   Boolean                  @default(false) @map("is_default_outbound")
  label               String?                  @map("label")
  purpose             WhatsappChannelPurpose    @default(GENERAL) @map("purpose")
  /** null = herdar `AiAgentConfig.auto_reply` do tenant. */
  autoReplyEnabled    Boolean?                 @map("auto_reply_enabled")
  /** Texto extra aplicado ao contexto do agente por canal; null = só config tenant. */
  aiProfileOverride   String?                  @map("ai_profile_override") @db.Text
  /** Preenchido na primeira transição para ACTIVE (manual ou OAuth); não sobrescrito em reativações. */
  activatedAt         DateTime?                @map("activated_at")
  /** Tentativas automáticas de correção (auto-healing); máximo 2. */
  autoHealAttempts    Int                      @default(0) @map("auto_heal_attempts")
  lastAutoHealAt      DateTime?                @map("last_auto_heal_at")
  /** Estado operacional da verificação Meta Business (checklist + decisões admin). */
  verificationStatus  MetaBusinessVerificationStatus @default(NOT_STARTED) @map("verification_status")
  /** Checklist JSON: `{ \"items\": [{ \"id\", \"label\", \"done\" }] }` — merge com defaults no serviço. */
  verificationChecklist Json @default("{}") @map("verification_checklist")
  verificationChecklistUpdatedAt DateTime? @map("verification_checklist_updated_at")
  verificationReadyAt            DateTime? @map("verification_ready_at")
  verificationSubmittedAt      DateTime? @map("verification_submitted_at")
  verificationApprovedAt       DateTime? @map("verification_approved_at")
  verificationRejectedAt       DateTime? @map("verification_rejected_at")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channelEvents       WhatsappChannelEvent[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([phoneNumberId])
  @@index([tenantId, isPrimary])
  @@index([tenantId, isDefaultOutbound])
  @@map("whatsapp_phone_numbers")
}

/** Eventos de diagnóstico / timeline de ativação (admin). */
model WhatsappChannelEvent {
  id        String   @id @default(cuid())
  channelId String   @map("channel_id")
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  channel   WhatsappPhoneNumber @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@map("whatsapp_channel_events")
}

model Tenant {
  id                   String         @id @default(cuid())
  name                 String?        @map("name")
  gtmLifecycle         TenantGtmLifecycle @default(AVALIACAO) @map("gtm_lifecycle")
  whatsappPhone        String?        @map("whatsapp_phone")
  systemPrompt         String?        @map("system_prompt") @db.Text
  defaultPrompt        String?        @map("default_prompt") @db.Text
  businessType         String?        @map("business_type")
  apiKey               String?        @unique @map("api_key")
  subdomain            String?        @unique @map("subdomain")
  stripeCustomerId     String?        @map("stripe_customer_id")
  plan                 String?        @map("plan")
  activeUntil          DateTime?      @map("active_until")
  aiDriver             String?        @map("ai_driver")  // ruleBased | openAI | claude
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  whatsappPhoneNumbers WhatsappPhoneNumber[]
  users                User[]
  agentStatuses        AgentStatus[]
  faqs                 FAQ[]
  waInboxThreads       WaInboxThread[]
  waInboxMessages      WaInboxMessage[]
  waInboxStatusHistory WaInboxStatusHistory[]
  waInboxTags          WaInboxTag[]
  waInboxAuditLogs     WaInboxAuditLog[]
  waInboxInternalNotes WaInboxInternalNote[]
  waAutomationRules    WaAutomationRule[]
  waAutomationPlaybooks WaAutomationPlaybook[]
  aiAgentConfig        AiAgentConfig?
  aiMessageLogs        AiMessageLog[]
  aiUsageLogs          AiUsageLog[]
  usageEvents          UsageEvent[]
  billingSubscription  BillingSubscription?
  billingAuditLogs     BillingAuditLog[]
  usageAggregates      UsageAggregate[]
  tenantSubscription   TenantSubscription?
  usageMetrics         UsageMetric[]
  emailMessages        EmailMessage[]
  waAutoReplyClaims    WaAutoReplyClaim[]
  followUpTasks        FollowUpTask[]
  waInboxQueues        WaInboxQueue[]
  waInboxQueueMemberships WaInboxQueueMembership[]
  operationalConfig    TenantOperationalConfig?
  webhookHealth        WebhookHealth?
  affiliateId          String?                @map("affiliate_id")
  /** `ref` = link de indicação no signup; `manual` = vínculo pela equipa (admin). */
  affiliateSource      String?                @map("affiliate_source")
  affiliate            Affiliate?             @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  commissions          Commission[]
  /** Valor fechado da implantação (BRL); obrigatório para gerar comissão de afiliado. */
  implantationPriceBrl Float?                 @map("implantation_price_brl")
  /** Workspace interno DevFlow (ex.: comercial) — mesmo modelo multi-tenant, marcado para operação/admin. */
  isInternal            Boolean                @default(false) @map("is_internal")

  @@index([affiliateId])
  @@index([isInternal])
  @@map("whatsapp_tenants")
}

/** Parceiro de indicação (comissão só em implantação — GTM). */
model Affiliate {
  id               String       @id @default(cuid())
  name             String
  email            String?
  phone            String?
  commissionRate   Float        @default(0.5) @map("commission_rate")
  createdAt        DateTime     @default(now()) @map("created_at")
  tenants          Tenant[]
  commissions      Commission[]

  @@map("whatsapp_affiliates")
}

/** Comissão por tenant (ex.: type `implantacao`). */
model Commission {
  id           String   @id @default(cuid())
  affiliateId  String   @map("affiliate_id")
  tenantId     String   @map("tenant_id")
  amount       Float
  type         String
  status       String   @default("pendente") @map("status")
  createdAt    DateTime @default(now()) @map("created_at")
  affiliate    Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([affiliateId])
  @@index([affiliateId, status])
  @@map("whatsapp_commissions")
}

/** Controlo operacional por tenant (pausas manuais sem alterar AiAgentConfig). */
model TenantOperationalConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique @map("tenant_id")
  aiEnabled           Boolean  @default(true) @map("ai_enabled")
  automationEnabled   Boolean  @default(true) @map("automation_enabled")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedByUserId     String?  @map("updated_by_user_id") @db.VarChar(128)
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_operational_configs")
}

/** Telemetria de saúde do webhook WhatsApp (atualizado no handler de entrada). */
model WebhookHealth {
  id             String    @id @default(cuid())
  tenantId       String    @unique @map("tenant_id")
  lastReceivedAt DateTime? @map("last_received_at")
  lastSuccessAt  DateTime? @map("last_success_at")
  lastErrorAt    DateTime? @map("last_error_at")
  totalReceived  Int       @default(0) @map("total_received")
  totalErrors    Int       @default(0) @map("total_errors")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("webhook_health")
}

/// Auditoria transversal (auth, automação, webhooks agregados). Inbox/thread continua em WaInboxAuditLog; billing detalhado em BillingAuditLog.
model AuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now()) @map("created_at")
  action       String   @map("action") @db.VarChar(64)
  tenantId     String?  @map("tenant_id")
  userId       String?  @map("user_id")
  resourceType String?  @map("resource_type") @db.VarChar(64)
  resourceId   String?  @map("resource_id") @db.VarChar(128)
  metadata     Json?    @map("metadata")
  ip           String?  @map("ip") @db.VarChar(128)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("platform_audit_logs")
}

enum UsageEventType {
  MESSAGE_SENT
  AI_RESPONSE
}

model UsageEvent {
  id                   String         @id @default(cuid())
  tenantId             String         @map("tenant_id")
  type                 UsageEventType @map("type")
  quantity             Int            @default(1) @map("quantity")
  metadata             Json?          @map("metadata")
  createdAt            DateTime       @default(now()) @map("created_at")
  reportedToStripeAt   DateTime?      @map("reported_to_stripe_at")
  stripeReportAttempts Int            @default(0) @map("stripe_report_attempts")
  stripeReportLastError String?       @map("stripe_report_last_error") @db.VarChar(2000)
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, reportedToStripeAt])
  @@map("usage_events")
}

model BillingSubscription {
  id                          String    @id @default(cuid())
  tenantId                    String    @unique @map("tenant_id")
  stripeCustomerId            String?   @map("stripe_customer_id")
  stripeSubscriptionId        String?   @unique @map("stripe_subscription_id")
  plan                        String    @map("plan")
  status                      String    @map("status")
  stripeMessagePriceId        String?   @map("stripe_message_price_id")
  stripeAiPriceId             String?   @map("stripe_ai_price_id")
  stripeSubscriptionItemMsgId String?   @map("stripe_subscription_item_msg_id")
  stripeSubscriptionItemAiId  String?   @map("stripe_subscription_item_ai_id")
  lastInvoiceId               String?   @map("last_invoice_id")
  lastInvoiceStatus           String?   @map("last_invoice_status") @db.VarChar(64)
  lastInvoiceAmountPaid       Int?      @map("last_invoice_amount_paid")
  currentPeriodStart          DateTime? @map("current_period_start")
  currentPeriodEnd            DateTime? @map("current_period_end")
  cancelAtPeriodEnd           Boolean   @default(false) @map("cancel_at_period_end")
  messagesIncludedUsed        Int       @default(0) @map("messages_included_used")
  aiIncludedUsed              Int       @default(0) @map("ai_included_used")
  messagesOverageSent         Int       @default(0) @map("messages_overage_sent")
  aiOverageSent               Int       @default(0) @map("ai_overage_sent")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("billing_subscriptions")
}

model StripeWebhookEvent {
  id         String   @id @default(cuid())
  stripeEventId String @unique @map("stripe_event_id")
  eventType  String   @map("event_type") @db.VarChar(128)
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([stripeEventId])
  @@map("stripe_webhook_events")
}

model BillingAuditLog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  eventType   String   @map("event_type") @db.VarChar(128)
  source      String   @map("source") @db.VarChar(32)
  referenceId String?  @map("reference_id") @db.VarChar(256)
  metadata    Json?    @map("metadata")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([source, eventType])
  @@index([referenceId, eventType])
  @@map("billing_audit_logs")
}

model UsageAggregate {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  period        String   @map("period")
  messagesCount Int      @default(0) @map("messages_count")
  aiCount       Int      @default(0) @map("ai_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId, period])
  @@map("usage_aggregates")
}

model TenantSubscription {
  id                    String    @id @default(cuid())
  tenantId              String    @unique @map("tenant_id")
  plan                  String    @map("plan")
  status                String    @map("status")
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_subscriptions")
}

enum UsageMetricType {
  MESSAGES
  AUTOMATIONS
  AI_CALLS
  USERS
}

model UsageMetric {
  id         String          @id @default(cuid())
  tenantId   String          @map("tenant_id")
  metricType UsageMetricType @map("metric_type")
  value      Int             @map("value")
  period     String          @map("period")
  createdAt  DateTime        @default(now()) @map("created_at")
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metricType, period])
  @@index([tenantId, period])
  @@map("usage_metrics")
}

enum AiAgentTone {
  FRIENDLY
  SALES
  SUPPORT
  NEUTRAL
}

model AiAgentConfig {
  id              String @id @default(cuid())
  tenantId        String @unique @map("tenant_id")
  enabled         Boolean @default(false) @map("enabled")
  model           String? @default("gpt-4o-mini") @map("model") @db.VarChar(128)
  tone            AiAgentTone @default(NEUTRAL) @map("tone")
  maxTokens       Int @default(512) @map("max_tokens")
  temperature     Float @default(0.7) @map("temperature")
  fallbackToHuman Boolean @default(true) @map("fallback_to_human")

  assistantName    String? @map("assistant_name") @db.VarChar(120)
  businessContext  String? @map("business_context") @db.Text
  goal             String? @map("goal") @db.Text
  rules            String[] @default([]) @map("rules")
  forbiddenTopics  String[] @default([]) @map("forbidden_topics")
  handoffTriggers  String[] @default([]) @map("handoff_triggers")
  autoReply        Boolean @default(true) @map("auto_reply")
  outOfHoursReply  String? @map("out_of_hours_reply") @db.Text
  /** ruleBased | openAI | claude — null herda Tenant.ai_driver */
  runtimeDriver    String? @map("runtime_driver") @db.VarChar(32)
  /** Objetivos/regras por estágio do funil (merge com defaults do produto) */
  playbookJson     Json?   @map("playbook_json")

  configVersion   Int @default(1) @map("config_version")
  updatedByUserId String? @map("updated_by_user_id") @db.VarChar(128)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_agent_configs")
}

model AiMessageLog {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  waInboxThreadId     String?  @map("wa_inbox_thread_id")
  inboundWaMessageId  String?  @map("inbound_wa_message_id")
  outboundWaMessageId String?  @map("outbound_wa_message_id")
  promptUsed          String   @map("prompt_used") @db.Text
  responseGenerated   String   @map("response_generated") @db.Text
  tokensUsed          Int?     @map("tokens_used")
  durationMs          Int?     @map("duration_ms")
  errorMessage        String?  @map("error_message") @db.VarChar(2000)
  /** auto_reply | fallback | error | blocked | test */
  eventKind           String   @default("auto_reply") @map("event_kind") @db.VarChar(32)
  decisionReason      String?  @map("decision_reason") @db.VarChar(512)
  modelUsed           String?  @map("model_used") @db.VarChar(128)
  providerKind        String?  @map("provider_kind") @db.VarChar(32)
  /** Snapshot do estágio do funil no momento do evento */
  aiStateSnapshot     String?  @map("ai_state_snapshot") @db.VarChar(32)
  /** Snapshot do lead score no momento do evento (análise futura) */
  leadScoreSnapshot   Int?     @map("lead_score_snapshot")
  createdAt           DateTime @default(now()) @map("created_at")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, eventKind])
  @@index([inboundWaMessageId])
  @@map("ai_message_logs")
}

enum AiUsageLogType {
  MESSAGE_TOTAL
  AI_SUCCESS
  AI_FALLBACK
  /** Simulação em /settings/ai — não conta como resposta de produção */
  AI_TEST_RUN
  /** Falha do provedor (timeout, 4xx/5xx) — observabilidade */
  AI_PROVIDER_ERROR
}

model AiUsageLog {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenant_id")
  type      AiUsageLogType @map("type")
  tokens    Int           @default(0) @map("tokens")
  createdAt DateTime      @default(now()) @map("created_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, type])
  @@map("ai_usage_logs")
}

// ─── Inbox Cloud API (multi-tenant, espelho operacional para UI) ───

enum WaInboxThreadStatus {
  OPEN
  CLOSED
  PENDING
}

/** Claim atómico: uma resposta automática por (tenant, thread, inbound Meta, fonte). */
enum WaAutoReplyClaimTrigger {
  LEGACY
  AI
  AUTOMATION
}

enum WaAutoReplyClaimStatus {
  PENDING
  SENT
  FAILED
  EXPIRED
}

model WaAutoReplyClaim {
  id                  String                 @id @default(cuid())
  tenantId            String                 @map("tenant_id")
  waInboxThreadId     String                 @map("wa_inbox_thread_id")
  inboundWaMessageId  String                 @map("inbound_wa_message_id") @db.VarChar(128)
  triggerSource       WaAutoReplyClaimTrigger @map("trigger_source")
  status              WaAutoReplyClaimStatus  @default(PENDING)
  claimToken          String                 @map("claim_token") @db.VarChar(64)
  expiresAt           DateTime               @map("expires_at")
  outboundWaMessageId String?                @map("outbound_wa_message_id") @db.VarChar(128)
  failureReason       String?                @map("failure_reason") @db.VarChar(256)
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread              WaInboxThread          @relation(fields: [waInboxThreadId], references: [id], onDelete: Cascade)

  @@unique([tenantId, waInboxThreadId, inboundWaMessageId, triggerSource])
  @@index([tenantId, waInboxThreadId])
  @@map("wa_auto_reply_claims")
}

/** Follow-up / reativação / recuperação comercial (fila processada por worker cron) */
model FollowUpTask {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  conversationId String   @map("conversation_id")
  scheduledAt    DateTime @map("scheduled_at")
  executed       Boolean  @default(false) @map("executed")
  /** followup | reactivation | recovery */
  type           String   @map("type") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread   WaInboxThread @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, scheduledAt])
  @@index([executed, scheduledAt])
  @@index([conversationId, executed])
  @@map("follow_up_tasks")
}

enum WaInboxThreadPriority {
  LOW
  MEDIUM
  HIGH
}

enum WaInboxDirection {
  INBOUND
  OUTBOUND
}

enum WaInboxMsgType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  UNKNOWN
}

enum WaInboxDeliveryStatus {
  RECEIVED
  SENT
  DELIVERED
  READ
  FAILED
}

model WaInboxQueue {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  name             String   @map("name")
  slug             String   @map("slug")
  description      String?  @map("description") @db.Text
  color            String?  @map("color") @db.VarChar(32)
  slaTargetMinutes Int?     @map("sla_target_minutes")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threads          WaInboxThread[]
  memberships      WaInboxQueueMembership[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("wa_inbox_queues")
}

model WaInboxQueueMembership {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  queueId   String   @map("queue_id")
  userId    String   @map("user_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  queue     WaInboxQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([tenantId, userId])
  @@index([queueId])
  @@map("wa_inbox_queue_memberships")
}

model WaInboxThread {
  id                     String                @id @default(cuid())
  tenantId               String                @map("tenant_id")
  queueId                String?               @map("queue_id")
  phoneNumber            String                @map("phone_number")
  /** phone_number_id (Meta) da linha WhatsApp Business desta conversa */
  businessPhoneNumberId  String                @map("business_phone_number_id")
  contactName            String?               @map("contact_name")
  lastMessageAt          DateTime              @default(now()) @map("last_message_at")
  unreadCount            Int                   @default(0) @map("unread_count")
  lastMessagePreview     String?               @map("last_message_preview") @db.VarChar(512)
  status                 WaInboxThreadStatus   @default(OPEN)
  priority               WaInboxThreadPriority @default(MEDIUM) @map("priority")
  assignedToUserId       String?               @map("assigned_to_user_id")
  lastCustomerMessageAt  DateTime?             @map("last_customer_message_at")
  lastAgentReplyAt       DateTime?             @map("last_agent_reply_at")
  firstResponseAt        DateTime?             @map("first_response_at")
  /** Playbook: lead | qualifying | negotiating | support | closed */
  aiState                String?               @map("ai_state") @db.VarChar(32)
  /** Pontuação CRM (MVP) — recalculada em cada inbound de texto */
  leadScore              Int                   @default(0) @map("lead_score")
  /** Dados extraídos heurísticamente do cliente (merge incremental) */
  leadData               Json?                 @map("lead_data")
  /**
   * ID do `outbound_leads` no BD do portal (`Lead.id`, Prisma raiz). Cross-database — sem FK PostgreSQL.
   * Espelha `Lead.conversationRef` → esta thread; necessário para funil, métricas e histórico comercial.
   */
  outboundLeadId         String?               @map("outbound_lead_id") @db.VarChar(40)
  /** Negociação comercial: null = em aberto; `won` / `lost` após fecho explícito. */
  dealStatus             String?               @map("deal_status") @db.VarChar(16)
  dealValue              Float?                @map("deal_value")
  dealCurrency           String                @default("BRL") @map("deal_currency") @db.VarChar(8)
  dealClosedAt           DateTime?             @map("deal_closed_at")
  /** Motivo de perda após fecho confirmado (`lost`). */
  dealLostReason         String?               @map("deal_lost_reason") @db.VarChar(32)
  /** Proposta de fecho à espera de confirmação do manager. */
  dealSuggested          Boolean               @default(false) @map("deal_suggested")
  dealSuggestedAt        DateTime?             @map("deal_suggested_at")
  dealSuggestedBy        String?               @map("deal_suggested_by") @db.VarChar(128)
  dealSuggestedStatus    String?               @map("deal_suggested_status") @db.VarChar(16)
  dealSuggestedValue     Float?                @map("deal_suggested_value")
  dealSuggestedLostReason String?              @map("deal_suggested_lost_reason") @db.VarChar(32)
  /** Cliente sinalizou hesitação (ex.: "vou pensar") — fila recuperação comercial */
  needsRecovery          Boolean               @default(false) @map("needs_recovery")
  /** Contador de automações comerciais enviadas (follow-up / reativação / recuperação) */
  commercialMsgCount     Int                   @default(0) @map("commercial_msg_count")
  /** Último envio automático comercial (anti-spam / intervalo mínimo) */
  lastCommercialMsgAt    DateTime?             @map("last_commercial_msg_at")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  queue                  WaInboxQueue?         @relation(fields: [queueId], references: [id], onDelete: SetNull)
  assignedToUser         User?                 @relation("AssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages               WaInboxMessage[]
  threadTags             WaInboxThreadTag[]
  internalNotes          WaInboxInternalNote[]
  autoReplyClaims        WaAutoReplyClaim[]
  followUpTasks          FollowUpTask[]

  @@unique([tenantId, phoneNumber, businessPhoneNumberId])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@index([tenantId, leadScore(sort: Desc)])
  @@index([tenantId, businessPhoneNumberId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, queueId])
  @@index([tenantId, outboundLeadId])
  @@index([tenantId, dealStatus])
  @@map("wa_inbox_threads")
}

model WaInboxTag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  color     String   @default("#6b7280") @map("color") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threadTags WaInboxThreadTag[]

  @@index([tenantId])
  @@map("wa_inbox_tags")
}

model WaInboxThreadTag {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenant_id")
  threadId  String        @map("thread_id")
  tagId     String        @map("tag_id")
  createdAt DateTime      @default(now()) @map("created_at")
  thread    WaInboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tag       WaInboxTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([threadId, tagId])
  @@index([tenantId, threadId])
  @@index([tenantId, tagId])
  @@map("wa_inbox_thread_tags")
}

model WaInboxInternalNote {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  body      String   @map("body") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread    WaInboxThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, threadId, createdAt(sort: Desc)])
  @@map("wa_inbox_internal_notes")
}

model WaInboxMessage {
  id           String                 @id @default(cuid())
  tenantId     String                 @map("tenant_id")
  threadId     String                 @map("thread_id")
  /** Denormalizado: mesma linha que o thread (Meta phone_number_id) */
  businessPhoneNumberId String        @map("business_phone_number_id")
  waMessageId  String                 @map("wa_message_id")
  direction    WaInboxDirection
  fromNumber   String                 @map("from_number")
  toNumber     String                 @map("to_number")
  messageType  WaInboxMsgType         @map("message_type")
  contentText  String?                @map("content_text") @db.Text
  contentJson  Json?                  @map("content_json")
  ts           DateTime               @map("ts")
  status       WaInboxDeliveryStatus
  errorCode    String?                @map("error_code")
  errorMessage String?                @map("error_message") @db.VarChar(2000)
  rawPayload   Json                   @map("raw_payload")
  createdAt    DateTime               @default(now()) @map("created_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread       WaInboxThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  statusHistory WaInboxStatusHistory[]

  @@unique([tenantId, waMessageId])
  @@index([tenantId, threadId, ts])
  @@index([tenantId, businessPhoneNumberId])
  @@map("wa_inbox_messages")
}

model WaInboxStatusHistory {
  id         String                 @id @default(cuid())
  tenantId   String                 @map("tenant_id")
  messageId  String                 @map("message_id")
  status     WaInboxDeliveryStatus
  ts         DateTime               @default(now()) @map("ts")
  rawPayload Json?                  @map("raw_payload")
  createdAt  DateTime               @default(now()) @map("created_at")
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message    WaInboxMessage         @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId, ts])
  @@map("wa_inbox_status_history")
}

model WaInboxAuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  action    String   @map("action")
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, threadId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("wa_inbox_audit_logs")
}

model WaAutomationRule {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String   @map("name")
  isActive    Boolean  @default(true) @map("is_active")
  /** Regras seed (v1); não remover na UI sem confirmação extra. */
  isSystem    Boolean  @default(false) @map("is_system")
  triggerType String   @map("trigger_type")
  conditions  Json     @map("conditions")
  actions     Json     @map("actions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, triggerType])
  @@map("wa_automation_rules")
}

model WaAutomationPlaybook {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  isActive  Boolean  @default(true) @map("is_active")
  steps     Json     @map("steps")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("wa_automation_playbooks")
}

model FAQ {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  question  String   @db.Text
  answer    String   @db.Text
  keywords  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("whatsapp_faqs")
}

model MessageFeedback {
  id             String   @id @default(cuid())
  messageId      String   @map("message_id")
  conversationId String   @map("conversation_id")
  rating         Int
  agentId        String?  @map("agent_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([messageId])
  @@map("whatsapp_message_feedback")
}

model User {
  id                   String          @id @default(cuid())
  tenantId              String          @map("tenant_id")
  email                 String          @unique
  passwordHash          String          @map("password_hash")
  name                  String
  role                  String
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedInboxThreads  WaInboxThread[] @relation("AssignedToUser")
  waInboxInternalNotes  WaInboxInternalNote[]
  sessions              UserSession[]
  emailMessages         EmailMessage[]
  agentStatus           AgentStatus?
  waInboxQueueMemberships WaInboxQueueMembership[]

  @@index([tenantId])
  @@index([email])
  @@map("whatsapp_users")
}

model EmailMessage {
  id                String              @id @default(cuid())
  tenantId          String?             @map("tenant_id")
  userId            String?             @map("user_id")
  type              String
  toEmail           String              @map("to_email")
  subject           String
  provider          String
  providerMessageId String?             @map("provider_message_id")
  status            EmailDeliveryStatus
  errorCode         String?             @map("error_code")
  errorMessage      String?             @map("error_message")
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  tenant            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("email_messages")
}

/// Sessão de browser: JWT carrega o mesmo id em `jti`; revogação invalida o token antes do exp.
model UserSession {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
  @@map("whatsapp_user_sessions")
}

model AgentStatus {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  /** Um utilizador = um registo de presença por tenant; `user_id` é único na tabela. */
  userId                String   @unique @map("user_id")
  status                String
  currentConversationId String?  @map("current_conversation_id")
  updatedAt             DateTime @updatedAt @map("updated_at")
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("whatsapp_agent_status")
}
