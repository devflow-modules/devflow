// WhatsApp Platform — dedicated WhatsApp DB (same as whatsapp-webhook-api).
datasource db {
  provider  = "postgresql"
  url       = env("WHATSAPP_DATABASE_URL")
  directUrl = env("WHATSAPP_DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-whatsapp"
}

enum WhatsappPhoneNumberStatus {
  PENDING
  ACTIVE
}

model WhatsappPhoneNumber {
  id                  String                   @id @default(cuid())
  tenantId            String                   @map("tenant_id")
  phoneNumberId       String                   @unique @map("phone_number_id")
  displayPhoneNumber  String?                  @map("display_phone_number")
  wabaId              String?                  @map("waba_id")
  accessToken         String                   @map("access_token")
  businessId          String?                  @map("business_id")
  status              WhatsappPhoneNumberStatus @default(PENDING) @map("status")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([phoneNumberId])
  @@map("whatsapp_phone_numbers")
}

model Tenant {
  id                   String         @id @default(cuid())
  name                 String?        @map("name")
  whatsappPhone        String?        @map("whatsapp_phone")
  systemPrompt         String?        @map("system_prompt") @db.Text
  defaultPrompt        String?        @map("default_prompt") @db.Text
  businessType         String?        @map("business_type")
  phoneNumberId        String?        @unique @map("phone_number_id")
  displayPhoneNumber   String?        @map("display_phone_number")
  accessToken          String?        @map("access_token")
  apiKey               String?        @unique @map("api_key")
  subdomain            String?        @unique @map("subdomain")
  stripeCustomerId     String?        @map("stripe_customer_id")
  plan                 String?        @map("plan")
  activeUntil          DateTime?      @map("active_until")
  aiDriver             String?        @map("ai_driver")  // ruleBased | openAI | claude
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  whatsappPhoneNumbers WhatsappPhoneNumber[]
  users                User[]
  conversations        Conversation[]
  conversationQueues   ConversationQueue[]
  agentStatuses        AgentStatus[]
  faqs                 FAQ[]
  waInboxThreads       WaInboxThread[]
  waInboxMessages      WaInboxMessage[]
  waInboxStatusHistory WaInboxStatusHistory[]
  waInboxTags          WaInboxTag[]
  waInboxAuditLogs     WaInboxAuditLog[]
  waAutomationRules    WaAutomationRule[]
  waAutomationPlaybooks WaAutomationPlaybook[]
  aiAgentConfig        AiAgentConfig?
  aiMessageLogs        AiMessageLog[]
  aiUsageLogs          AiUsageLog[]
  usageEvents          UsageEvent[]
  billingSubscription  BillingSubscription?
  billingAuditLogs     BillingAuditLog[]
  usageAggregates      UsageAggregate[]
  tenantSubscription   TenantSubscription?
  usageMetrics         UsageMetric[]

  @@map("whatsapp_tenants")
}

enum UsageEventType {
  MESSAGE_SENT
  AI_RESPONSE
}

model UsageEvent {
  id                   String         @id @default(cuid())
  tenantId             String         @map("tenant_id")
  type                 UsageEventType @map("type")
  quantity             Int            @default(1) @map("quantity")
  metadata             Json?          @map("metadata")
  createdAt            DateTime       @default(now()) @map("created_at")
  reportedToStripeAt   DateTime?      @map("reported_to_stripe_at")
  stripeReportAttempts Int            @default(0) @map("stripe_report_attempts")
  stripeReportLastError String?       @map("stripe_report_last_error") @db.VarChar(2000)
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, reportedToStripeAt])
  @@map("usage_events")
}

model BillingSubscription {
  id                          String    @id @default(cuid())
  tenantId                    String    @unique @map("tenant_id")
  stripeCustomerId            String?   @map("stripe_customer_id")
  stripeSubscriptionId        String?   @unique @map("stripe_subscription_id")
  plan                        String    @map("plan")
  status                      String    @map("status")
  stripeMessagePriceId        String?   @map("stripe_message_price_id")
  stripeAiPriceId             String?   @map("stripe_ai_price_id")
  stripeSubscriptionItemMsgId String?   @map("stripe_subscription_item_msg_id")
  stripeSubscriptionItemAiId  String?   @map("stripe_subscription_item_ai_id")
  lastInvoiceId               String?   @map("last_invoice_id")
  lastInvoiceStatus           String?   @map("last_invoice_status") @db.VarChar(64)
  lastInvoiceAmountPaid       Int?      @map("last_invoice_amount_paid")
  currentPeriodStart          DateTime? @map("current_period_start")
  currentPeriodEnd            DateTime? @map("current_period_end")
  cancelAtPeriodEnd           Boolean   @default(false) @map("cancel_at_period_end")
  messagesIncludedUsed        Int       @default(0) @map("messages_included_used")
  aiIncludedUsed              Int       @default(0) @map("ai_included_used")
  messagesOverageSent         Int       @default(0) @map("messages_overage_sent")
  aiOverageSent               Int       @default(0) @map("ai_overage_sent")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("billing_subscriptions")
}

model StripeWebhookEvent {
  id         String   @id @default(cuid())
  stripeEventId String @unique @map("stripe_event_id")
  eventType  String   @map("event_type") @db.VarChar(128)
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([stripeEventId])
  @@map("stripe_webhook_events")
}

model BillingAuditLog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  eventType   String   @map("event_type") @db.VarChar(128)
  source      String   @map("source") @db.VarChar(32)
  referenceId String?  @map("reference_id") @db.VarChar(256)
  metadata    Json?    @map("metadata")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([source, eventType])
  @@index([referenceId, eventType])
  @@map("billing_audit_logs")
}

model UsageAggregate {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  period        String   @map("period")
  messagesCount Int      @default(0) @map("messages_count")
  aiCount       Int      @default(0) @map("ai_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId, period])
  @@map("usage_aggregates")
}

model TenantSubscription {
  id                    String    @id @default(cuid())
  tenantId              String    @unique @map("tenant_id")
  plan                  String    @map("plan")
  status                String    @map("status")
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_subscriptions")
}

enum UsageMetricType {
  MESSAGES
  AUTOMATIONS
  AI_CALLS
  USERS
}

model UsageMetric {
  id         String          @id @default(cuid())
  tenantId   String          @map("tenant_id")
  metricType UsageMetricType @map("metric_type")
  value      Int             @map("value")
  period     String          @map("period")
  createdAt  DateTime        @default(now()) @map("created_at")
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metricType, period])
  @@index([tenantId, period])
  @@map("usage_metrics")
}

enum AiAgentTone {
  FRIENDLY
  SALES
  SUPPORT
  NEUTRAL
}

model AiAgentConfig {
  id                 String      @id @default(cuid())
  tenantId           String      @unique @map("tenant_id")
  enabled            Boolean     @default(false) @map("enabled")
  systemPrompt       String      @default("") @map("system_prompt") @db.Text
  model              String?     @default("gpt-4o-mini") @map("model") @db.VarChar(128)
  tone               AiAgentTone @default(NEUTRAL) @map("tone")
  maxTokens          Int         @default(512) @map("max_tokens")
  temperature        Float       @default(0.7) @map("temperature")
  fallbackToHuman    Boolean     @default(true) @map("fallback_to_human")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_agent_configs")
}

model AiMessageLog {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  waInboxThreadId      String?  @map("wa_inbox_thread_id")
  inboundWaMessageId   String?  @map("inbound_wa_message_id")
  outboundWaMessageId  String?  @map("outbound_wa_message_id")
  promptUsed           String   @map("prompt_used") @db.Text
  responseGenerated    String   @map("response_generated") @db.Text
  tokensUsed           Int?     @map("tokens_used")
  durationMs           Int?     @map("duration_ms")
  errorMessage         String?  @map("error_message") @db.VarChar(2000)
  createdAt            DateTime @default(now()) @map("created_at")
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([inboundWaMessageId])
  @@map("ai_message_logs")
}

enum AiUsageLogType {
  MESSAGE_TOTAL
  AI_SUCCESS
  AI_FALLBACK
}

model AiUsageLog {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenant_id")
  type      AiUsageLogType @map("type")
  tokens    Int           @default(0) @map("tokens")
  createdAt DateTime      @default(now()) @map("created_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, type])
  @@map("ai_usage_logs")
}

// ─── Inbox Cloud API (multi-tenant, espelho operacional para UI) ───

enum WaInboxThreadStatus {
  OPEN
  CLOSED
  PENDING
}

enum WaInboxThreadPriority {
  LOW
  MEDIUM
  HIGH
}

enum WaInboxDirection {
  INBOUND
  OUTBOUND
}

enum WaInboxMsgType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  UNKNOWN
}

enum WaInboxDeliveryStatus {
  RECEIVED
  SENT
  DELIVERED
  READ
  FAILED
}

model WaInboxThread {
  id                     String                @id @default(cuid())
  tenantId               String                @map("tenant_id")
  phoneNumber            String                @map("phone_number")
  contactName            String?               @map("contact_name")
  lastMessageAt          DateTime              @default(now()) @map("last_message_at")
  unreadCount            Int                   @default(0) @map("unread_count")
  lastMessagePreview     String?               @map("last_message_preview") @db.VarChar(512)
  status                 WaInboxThreadStatus   @default(OPEN)
  priority               WaInboxThreadPriority @default(MEDIUM) @map("priority")
  assignedToUserId       String?               @map("assigned_to_user_id")
  lastCustomerMessageAt  DateTime?             @map("last_customer_message_at")
  lastAgentReplyAt       DateTime?             @map("last_agent_reply_at")
  firstResponseAt        DateTime?             @map("first_response_at")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedToUser         User?                 @relation("AssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages               WaInboxMessage[]
  threadTags             WaInboxThreadTag[]

  @@unique([tenantId, phoneNumber])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@index([tenantId, status])
  @@index([tenantId, assignedToUserId])
  @@map("wa_inbox_threads")
}

model WaInboxTag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  color     String   @default("#6b7280") @map("color") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threadTags WaInboxThreadTag[]

  @@index([tenantId])
  @@map("wa_inbox_tags")
}

model WaInboxThreadTag {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenant_id")
  threadId  String        @map("thread_id")
  tagId     String        @map("tag_id")
  createdAt DateTime      @default(now()) @map("created_at")
  thread    WaInboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tag       WaInboxTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([threadId, tagId])
  @@index([tenantId, threadId])
  @@index([tenantId, tagId])
  @@map("wa_inbox_thread_tags")
}

model WaInboxMessage {
  id           String                 @id @default(cuid())
  tenantId     String                 @map("tenant_id")
  threadId     String                 @map("thread_id")
  waMessageId  String                 @map("wa_message_id")
  direction    WaInboxDirection
  fromNumber   String                 @map("from_number")
  toNumber     String                 @map("to_number")
  messageType  WaInboxMsgType         @map("message_type")
  contentText  String?                @map("content_text") @db.Text
  contentJson  Json?                  @map("content_json")
  ts           DateTime               @map("ts")
  status       WaInboxDeliveryStatus
  errorCode    String?                @map("error_code")
  errorMessage String?                @map("error_message") @db.VarChar(2000)
  rawPayload   Json                   @map("raw_payload")
  createdAt    DateTime               @default(now()) @map("created_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread       WaInboxThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  statusHistory WaInboxStatusHistory[]

  @@unique([tenantId, waMessageId])
  @@index([tenantId, threadId, ts])
  @@map("wa_inbox_messages")
}

model WaInboxStatusHistory {
  id         String                 @id @default(cuid())
  tenantId   String                 @map("tenant_id")
  messageId  String                 @map("message_id")
  status     WaInboxDeliveryStatus
  ts         DateTime               @default(now()) @map("ts")
  rawPayload Json?                  @map("raw_payload")
  createdAt  DateTime               @default(now()) @map("created_at")
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message    WaInboxMessage         @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId, ts])
  @@map("wa_inbox_status_history")
}

model WaInboxAuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  action    String   @map("action")
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, threadId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("wa_inbox_audit_logs")
}

model WaAutomationRule {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String   @map("name")
  isActive    Boolean  @default(true) @map("is_active")
  triggerType String   @map("trigger_type")
  conditions  Json     @map("conditions")
  actions     Json     @map("actions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, triggerType])
  @@map("wa_automation_rules")
}

model WaAutomationPlaybook {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  isActive  Boolean  @default(true) @map("is_active")
  steps     Json     @map("steps")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("wa_automation_playbooks")
}

model FAQ {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  question  String   @db.Text
  answer    String   @db.Text
  keywords  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("whatsapp_faqs")
}

model MessageFeedback {
  id             String   @id @default(cuid())
  messageId      String   @map("message_id")
  conversationId String   @map("conversation_id")
  rating         Int
  agentId        String?  @map("agent_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([messageId])
  @@map("whatsapp_message_feedback")
}

model User {
  id                   String          @id @default(cuid())
  tenantId              String          @map("tenant_id")
  email                 String          @unique
  passwordHash          String          @map("password_hash")
  name                  String
  role                  String
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedInboxThreads  WaInboxThread[] @relation("AssignedToUser")

  @@index([tenantId])
  @@index([email])
  @@map("whatsapp_users")
}

model Conversation {
  id            String              @id @default(cuid())
  tenantId      String              @map("tenant_id")
  externalId    String              @map("external_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages      Message[]
  queueEntries  ConversationQueue[]

  @@unique([tenantId, externalId])
  @@map("whatsapp_conversations")
}

model ConversationQueue {
  id             String       @id @default(cuid())
  tenantId       String       @map("tenant_id")
  conversationId String       @map("conversation_id")
  priority       Int          @default(0)
  queuedAt       DateTime     @default(now()) @map("queued_at")
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, queuedAt])
  @@map("whatsapp_conversation_queue")
}

model AgentStatus {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  userId                String   @map("user_id")
  status                String
  currentConversationId String?  @map("current_conversation_id")
  updatedAt             DateTime @updatedAt @map("updated_at")
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@map("whatsapp_agent_status")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  sender         String
  messageType    String       @map("message_type")
  content        String       @db.Text
  timestamp      DateTime     @default(now())
  responseTimeMs Int?     @map("response_time_ms")
  agentId        String?  @map("agent_id")
  intent         String?      @map("intent")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("whatsapp_messages")
}
