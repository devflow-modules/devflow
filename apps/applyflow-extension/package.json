  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.0",
    "typescript": "^5",
    "vite": "^6.0.3",
    "vitest": "^4.1.0"
  }
