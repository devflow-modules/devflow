# ─── DevFlow Financeiro — STAGING ─────────────────────────────────────────
# Copie para .env.staging (não commitar) e preencha com o Postgres de staging.

# Ambiente explícito (use em build/deploy staging)
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=staging

# Banco dedicado staging (nunca use produção aqui)
DATABASE_URL="postgresql://USER:PASS@HOST:5432/financeiro_staging?schema=public"
DIRECT_URL="postgresql://USER:PASS@HOST:5432/financeiro_staging?schema=public"

# Supabase do projeto staging (auth)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Opcional server-side se o app usar
# SUPABASE_SERVICE_ROLE_KEY=

# URL pública — produção canônica: https://devflowlabs.com.br (Financeiro em /ferramentas/financeiro)
NEXT_PUBLIC_APP_URL=https://devflowlabs.com.br

# Staging próprio (se existir): substitua pelo host real
# NEXT_PUBLIC_APP_URL=https://financeiro-staging.seudominio.com

# Opcional: smoke (cookie após login)
# FINANCEIRO_SMOKE_COOKIE=
# FINANCEIRO_SMOKE_BASE_URL=https://devflowlabs.com.br
