{
  "name": "@devflow/app-financeiro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "vitest run e2e --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env.local -e .env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env.local -e .env -- prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:reset": "tsx prisma/seed.ts --reset",
    "seed:demo": "dotenv -e ../../.env.local -e .env -- tsx scripts/seed-financeiro-demo.ts",
    "smoke": "tsx scripts/smoke-financeiro.ts",
    "validate:supabase-user": "dotenv -e ../../.env.local -e .env -- tsx scripts/validate-user-supabase.ts"
  },
  "dependencies": {
    "@devflow/analytics-core": "workspace:*",
    "@devflow/billing-core": "workspace:*",
    "@devflow/ui": "workspace:*",
    "@prisma/client": "^6.0.0",
    "stripe": "^17.0.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.49.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^2.15.0",
    "shadcn": "^4.0.2",
    "@vercel/analytics": "^1.4.0",
    "resend": "^4.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
