datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Household {
  id                      String                    @id @default(cuid())
  name                    String
  slug                    String                    @unique
  timezone                String                    @default("America/Sao_Paulo")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  memberships             HouseholdMembership[]
  invites                 Invite[]
  auditLogs               AuditLog[]
  sources                 Source[]
  incomes                 Income[]
  expenses                Expense[]
  categories              Category[]
  budgets                 Budget[]
  rules                   Rule[]
  incomeAllocationGoals   IncomeAllocationGoal[]
  personalAllocationGoals PersonalAllocationGoal[]
  cycles                  Cycle[]
  monthSnapshots          MonthSnapshot[]
  accounts                Account[]
  idempotencyRecords      IdempotencyRecord[]
}

model User {
  id                     String                   @id @default(cuid())
  supabaseId             String?                  @unique
  email                  String                   @unique
  name                   String?
  avatarUrl              String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  memberships            HouseholdMembership[]
  acceptedInvites        Invite[]
  auditLogs              AuditLog[]
  marketingEvents        MarketingEvent[]
  personalAllocationGoals PersonalAllocationGoal[]
  userPlan               UserPlan?
  userBillingProfile     UserBillingProfile?
  tenantSubscription     TenantSubscription?
}

model UserPlan {
  id        String   @id @default(cuid())
  userId   String   @unique
  planId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBillingProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Assinatura Stripe (tenantId = userId no Financeiro).
model TenantSubscription {
  id                   String    @id @default(cuid())
  tenantId             String    @unique @map("tenant_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  planCode             String    @default("free") @map("plan_code")
  status               String    @default("inactive") @map("status")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
}

model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique @map("stripe_event_id")
  eventType     String    @map("event_type")
  payloadJson   Json      @map("payload_json")
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("stripe_webhook_events")
}

enum MembershipRole {
  OWNER
  MEMBER
}

model HouseholdMembership {
  id          String           @id @default(cuid())
  userId      String
  householdId String
  role        MembershipRole   @default(MEMBER)
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id])
  household   Household        @relation(fields: [householdId], references: [id])
  sources     Source[]
  @@unique([userId, householdId])
}

model Invite {
  id              String         @id @default(cuid())
  householdId     String
  email           String
  role            MembershipRole @default(MEMBER)
  token           String         @unique
  expiresAt       DateTime
  createdAt       DateTime       @default(now())
  acceptedAt      DateTime?
  acceptedByUserId String?

  household       Household      @relation(fields: [householdId], references: [id])
  acceptedBy      User?          @relation(fields: [acceptedByUserId], references: [id])

  @@index([householdId, email])
}

model AuditLog {
  id          String   @id @default(cuid())
  householdId String
  userId      String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([householdId, createdAt])
  @@index([userId, createdAt])
}

model IncomeAllocationGoal {
  id               String   @id @default(cuid())
  householdId      String
  year             Int
  month            Int
  investmentPercent Decimal? @db.Decimal(5, 2)
  savingsPercent    Decimal? @db.Decimal(5, 2)
  investmentAmount  Decimal? @db.Decimal(10, 2)
  savingsAmount     Decimal? @db.Decimal(10, 2)
  observations     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  household        Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, year, month])
  @@index([householdId, year, month])
}

model PersonalAllocationGoal {
  id                String    @id @default(cuid())
  userId            String
  householdId       String
  year             Int
  month            Int
  investmentPercent Decimal?  @db.Decimal(5, 2)
  savingsPercent    Decimal?  @db.Decimal(5, 2)
  investmentAmount  Decimal?  @db.Decimal(10, 2)
  savingsAmount     Decimal?  @db.Decimal(10, 2)
  observations     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId, year, month])
  @@index([householdId, year, month])
  @@index([userId, householdId, year, month])
}

enum SourceType {
  PJ
  PF
}

enum FinancialContext {
  PERSONAL   // vida pessoal / PF
  BUSINESS   // empresa / PJ
  SHARED     // estúdio / sociedade
}

model Source {
  id            String          @id @default(cuid())
  householdId   String
  membershipId  String?
  name          String
  sourceType    SourceType
  description   String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  household     Household       @relation(fields: [householdId], references: [id])
  membership    HouseholdMembership? @relation(fields: [membershipId], references: [id])
  paymentDays   PaymentDay[]
  incomes       Income[]
  expenses      Expense[]
  ruleSources   RuleSource[]
}

enum CycleType {
  MONTHLY
  WEEKLY
}

model Cycle {
  id             String       @id @default(cuid())
  householdId    String
  name           String
  cycleType      CycleType    @default(MONTHLY)
  anchorDay      Int?         // 1-31 para MONTHLY: ciclo do dia N ao dia N-1 do mês seguinte
  anchorWeekDay  Int?         // 0-6 para WEEKLY: 0=domingo, 1=segunda, ... 6=sábado (início do ciclo)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  household      Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentDays    PaymentDay[]

  @@index([householdId])
}

model PaymentDay {
  id        String   @id @default(cuid())
  sourceId  String
  dayOfMonth Int
  description String?
  cycleId   String?
  source    Source   @relation(fields: [sourceId], references: [id])
  cycle     Cycle?   @relation(fields: [cycleId], references: [id], onDelete: SetNull)
}

enum IncomeStatus {
  SCHEDULED
  RECEIVED
}

model Income {
  id                 String           @id @default(cuid())
  householdId        String
  sourceId           String?
  amount             Decimal          @db.Decimal(10, 2)
  receivedAt         DateTime
  isRecurring        Boolean          @default(false)
  recurrenceParentId String?          // ID da receita-template que gerou esta instância
  status             IncomeStatus     @default(RECEIVED)
  notes              String?
  context            FinancialContext @default(PERSONAL)
  household          Household        @relation(fields: [householdId], references: [id])
  source             Source?          @relation(fields: [sourceId], references: [id])
  recurrenceChildren Income[]         @relation("IncomeRecurrenceTemplate")
  recurrenceParent   Income?          @relation("IncomeRecurrenceTemplate", fields: [recurrenceParentId], references: [id], onDelete: SetNull)

  @@index([householdId, context])
  @@index([recurrenceParentId])
}

enum ExpenseStatus {
  PENDING
  PAID
  SCHEDULED
}

enum MarketingChannel {
  EMAIL
  WHATSAPP
}

enum MarketingMessageStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model Category {
  id          String    @id @default(cuid())
  householdId String
  name        String
  color       String    @default("#6366f1")
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  budgets     Budget[]

  @@index([householdId])
}

model Budget {
  id            String   @id @default(cuid())
  householdId   String
  categoryId    String
  monthlyLimit  Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([householdId, categoryId])
  @@index([householdId])
}

enum ExpenseSplitType {
  SHARED    // divisão proporcional entre participantes da conta
  INDIVIDUAL // 100% para um participante (ex.: luz só Gustavo)
}

model Account {
  id          String              @id @default(cuid())
  householdId String
  name        String
  type        FinancialContext    @default(PERSONAL) // personal | shared | business
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  household   Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  participants AccountParticipant[]
  expenses    Expense[]
  settlements Settlement[]
  snapshots   AccountSnapshot[]

  @@index([householdId])
}

model IdempotencyRecord {
  id          String    @id @default(cuid())
  householdId String
  key         String
  response    Json
  statusCode  Int       @default(200)
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, key])
  @@index([householdId])
}

model AccountSnapshot {
  id        String   @id @default(cuid())
  accountId String
  month     String
  balances  Json
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, month])
  @@index([accountId])
}

enum SettlementStatus {
  PENDING
  PARTIAL   // paidAmount > 0 e paidAmount < amount
  COMPLETED
}

model Settlement {
  id                 String           @id @default(cuid())
  accountId          String
  fromParticipantId  String
  toParticipantId   String
  amount             Decimal          @db.Decimal(10, 2)
  paidAmount         Decimal          @db.Decimal(10, 2) @default(0)
  status             SettlementStatus @default(PENDING)
  completedAt        DateTime?
  reopenedAt         DateTime?        // reaberto para ajustes; impede auto-COMPLETED até finalizar
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  account            Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fromParticipant    AccountParticipant @relation("SettlementFrom", fields: [fromParticipantId], references: [id], onDelete: Cascade)
  toParticipant      AccountParticipant @relation("SettlementTo", fields: [toParticipantId], references: [id], onDelete: Cascade)
  payments           Payment[]

  @@index([accountId])
  @@index([fromParticipantId])
  @@index([toParticipantId])
  @@index([status])
}

model Payment {
  id           String            @id @default(cuid())
  settlementId String
  amount       Decimal           @db.Decimal(10, 2)
  createdAt    DateTime          @default(now())
  settlement   Settlement        @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  reversals    PaymentReversal[]

  @@index([settlementId])
}

model PaymentReversal {
  id        String   @id @default(cuid())
  paymentId String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model AccountParticipant {
  id            String    @id @default(cuid())
  accountId     String
  name          String
  defaultShare  Decimal   @db.Decimal(5, 4) // 0..1, ex: 0.7 = 70%
  userId        String?   // opcional: vincula ao User do app (não unique: mesmo user em contas diferentes)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  account          Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expenseSplits    ExpenseSplit[]
  expensesPaid     Expense[]    @relation("ExpensePaidBy")
  settlementsFrom Settlement[]  @relation("SettlementFrom")
  settlementsTo   Settlement[]  @relation("SettlementTo")

  @@index([accountId])
  @@index([userId])
}

model ExpenseSplit {
  id             String   @id @default(cuid())
  expenseId      String
  participantId String
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  expense        Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant    AccountParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([expenseId, participantId])
  @@index([expenseId])
  @@index([participantId])
}

model Expense {
  id                   String           @id @default(cuid())
  householdId          String
  accountId            String?          // quando preenchido: usa participantes da conta e split
  sourceId             String?
  categoryId           String?
  category             String           // legacy: free text when categoryId is null
  amount               Decimal          @db.Decimal(10, 2)
  dueDate              DateTime
  paidAmount           Decimal?         @db.Decimal(10, 2)
  paidAt               DateTime?
  isRecurring          Boolean          @default(false)
  recurrenceParentId   String?          // ID da despesa-template que gerou esta instância
  status               ExpenseStatus   @default(PENDING)
  note                 String?
  context              FinancialContext @default(PERSONAL)
  expenseSplitType     ExpenseSplitType @default(SHARED) // shared = proporcional; individual = 100% paidByParticipantId
  paidByParticipantId  String?          // quando individual: quem pagou (100%)
  household            Household        @relation(fields: [householdId], references: [id])
  account              Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  paidByParticipant    AccountParticipant? @relation("ExpensePaidBy", fields: [paidByParticipantId], references: [id], onDelete: SetNull)
  source               Source?          @relation(fields: [sourceId], references: [id])
  categoryRef          Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurrenceChildren   Expense[]        @relation("RecurrenceTemplate")
  recurrenceParent     Expense?         @relation("RecurrenceTemplate", fields: [recurrenceParentId], references: [id], onDelete: SetNull)
  splits               ExpenseSplit[]

  @@index([householdId, context])
  @@index([householdId, dueDate])
  @@index([householdId, isRecurring])
  @@index([recurrenceParentId])
  @@index([accountId])
}

model MonthSnapshot {
  id              String   @id @default(cuid())
  householdId     String
  year            Int
  month           Int
  totalIncomes    Decimal  @db.Decimal(10, 2)
  totalExpenses   Decimal  @db.Decimal(10, 2)
  balance         Decimal  @db.Decimal(10, 2)
  pendingExpenses Decimal  @db.Decimal(10, 2) @default(0)
  notes           String?
  closedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, year, month])
  @@index([householdId, year, month])
}

model FinanceiroLead {
  id        String   @id @default(cuid())
  email     String
  source    String
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}

model MarketingLead {
  id                 String                     @id @default(cuid())
  email              String                     @unique
  whatsapp           String?
  goal               String?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  landingPath        String?
  referrer           String?
  consentEmail       Boolean                    @default(false)
  consentWhatsapp    Boolean                    @default(false)
  consentTextVersion String
  consentedAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  consents           MarketingConsent[]
  events             MarketingEvent[]
  schedules          MarketingMessageSchedule[]

  @@index([createdAt])
}

model MarketingConsent {
  id                 String           @id @default(cuid())
  leadId             String
  channel            MarketingChannel
  consentTextVersion String
  consentedAt        DateTime         @default(now())
  ip                 String?
  userAgent          String?
  createdAt          DateTime         @default(now())
  lead               MarketingLead    @relation(fields: [leadId], references: [id])

  @@index([leadId])
}

model MarketingEvent {
  id        String        @id @default(cuid())
  leadId    String?
  userId    String?
  event     String
  payload   Json?
  createdAt DateTime      @default(now())
  lead      MarketingLead? @relation(fields: [leadId], references: [id])
  user      User?         @relation(fields: [userId], references: [id])

  @@index([leadId, createdAt])
  @@index([userId, createdAt])
}

model MarketingMessageSchedule {
  id           String                 @id @default(cuid())
  leadId       String
  channel      MarketingChannel
  templateKey  String
  status       MarketingMessageStatus @default(PENDING)
  scheduledFor DateTime
  sentAt       DateTime?
  lastError    String?
  createdAt    DateTime               @default(now())
  lead         MarketingLead          @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([channel, status, scheduledFor])
  @@unique([leadId, channel, templateKey])
}

enum RuleType {
  CATEGORY_PERCENTAGE
  FIXED_PER_MEMBER
}

model Rule {
  id                 String        @id @default(cuid())
  householdId        String
  name               String
  description        String?
  ruleType           RuleType
  percentage         Decimal?      @db.Decimal(5, 2)
  fixedAmount        Decimal?      @db.Decimal(10, 2)
  referenceCategory  String?
  createdAt          DateTime      @default(now())
  household          Household     @relation(fields: [householdId], references: [id])
  ruleSources        RuleSource[]
}

model RuleSource {
  id        String   @id @default(cuid())
  ruleId    String
  sourceId  String
  share     Decimal? @db.Decimal(5, 2)
  rule      Rule     @relation(fields: [ruleId], references: [id])
  source    Source   @relation(fields: [sourceId], references: [id])
}
