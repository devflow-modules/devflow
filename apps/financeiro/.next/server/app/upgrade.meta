{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/upgrade/layout,_N_T_/upgrade/page,_N_T_/upgrade"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/upgrade/__PAGE__",
    "/upgrade",
    "/_index",
    "/_head"
  ]
}