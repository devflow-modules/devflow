# ApplyFlow — provider runtime (local sandbox validation only)
#
# Copy to .env.local for local development. Never commit real secrets.
# All flags default to disabled when unset. See:
# docs/career-suite/integrations/NANGO-SANDBOX-RUNTIME-VALIDATION-RUNBOOK.md

# --- Feature flags (server-only; default-off) ---
# CAREER_PROVIDER_RUNTIME_ENABLED=true
# NANGO_RUNTIME_ENABLED=true
# GMAIL_PROVIDER_ENABLED=true
# CALENDAR_PROVIDER_ENABLED=true
# LIBRECHAT_ADAPTER_ENABLED=true

# --- Nango (server-only secret) ---
# NANGO_SECRET_KEY=replace_me

# Nango integration config keys are code-defined (not env):
#   gmail    → google-mail
#   calendar → google-calendar
#
# OAuth scopes (code-defined):
#   gmail    → gmail.metadata.read
#   calendar → calendar.events.read
