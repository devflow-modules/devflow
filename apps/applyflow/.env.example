# ApplyFlow — provider runtime (local sandbox validation only)
#
# Copy to .env.local for local development. Never commit real secrets.
# All flags default to disabled when unset. See:
# docs/career-suite/integrations/NANGO-SANDBOX-RUNTIME-VALIDATION-RUNBOOK.md

# --- Feature flags (server-only; default-off) ---
# CAREER_PROVIDER_RUNTIME_ENABLED=true
# NANGO_RUNTIME_ENABLED=true
# GMAIL_PROVIDER_ENABLED=true
# CALENDAR_PROVIDER_ENABLED=true
# LIBRECHAT_ADAPTER_ENABLED=true
# CAREER_LLM_ENABLED=true

# --- LibreChat adapter boundary (server-only; default-off) ---
# LIBRECHAT_ADAPTER_ENABLED=true

# --- LibreChat real transport (server-only; default-off) ---
# Delivers LibreChat server payloads to POST /career-chat/librechat only.
# Secrets stay server-side; never expose LIBRECHAT_API_KEY to the client.
# LIBRECHAT_TRANSPORT_ENABLED=false
# LIBRECHAT_BASE_URL=
# LIBRECHAT_API_KEY=
# LIBRECHAT_TIMEOUT_MS=10000

# --- Controlled LLM boundary (server-only; default-off) ---
# CAREER_LLM_PROVIDER defaults to "mock" (deterministic, no network, no cost).
# Set to "openai" only with a server-side key AND model; never expose secrets to the client.
# The OpenAI adapter uses the Responses API with strict Structured Outputs (no tools,
# no streaming, store:false). There is no silent fallback from openai to mock: an
# unconfigured openai provider is reported as not configured and blocked by policy.
# The model is server-owned (no hardcoded model, never client-provided).
# CAREER_LLM_ENABLED=false
# CAREER_LLM_PROVIDER=mock
# OPENAI_API_KEY=
# CAREER_LLM_MODEL=
# CAREER_LLM_TIMEOUT_MS=15000
# CAREER_LLM_MAX_RETRIES=1

# --- Approved automation boundary (server-only; default-off) ---
# Runs a single, explicitly approved, non-destructive automation. No schedule,
# queue, worker, background processing, or persistence. Default provider is the
# deterministic in-memory mock (no network, no cost).
# CAREER_AUTOMATION_ENABLED=true
# CAREER_AUTOMATION_PROVIDER=mock
# Optional OpenClaw adapter (server-side only; secrets never reach the client):
# CAREER_AUTOMATION_PROVIDER=openclaw
# OPENCLAW_API_KEY=replace_me
# OPENCLAW_BASE_URL=https://replace_me

# --- Nango (server-only secret) ---
# NANGO_SECRET_KEY=replace_me

# Nango integration config keys are code-defined (not env):
#   gmail    → google-mail
#   calendar → google-calendar
#
# OAuth scopes (code-defined):
#   gmail    → gmail.metadata.read
#   calendar → calendar.events.read
