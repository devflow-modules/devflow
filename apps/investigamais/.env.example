# Investiga+ — variáveis de ambiente
# Copiar para .env.local

# JWT (obrigatório para login e middleware)
JWT_SECRET=your-secret-min-32-chars

# Supabase (obrigatório para persistência)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ReceitaWS (consulta CNPJ)
RECEITAWS_API_URL=https://receitaws.com.br/v1

# Cookie (opcional; em produção definir domínio)
COOKIE_DOMAIN=

# Admin metrics (produção: protege /admin/metrics e /api/admin/metrics)
# ADMIN_METRICS_SECRET=your-admin-secret

# Stripe (faturamento e Customer Portal)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_TEST_SECRET_KEY=sk_test_... (desenvolvimento)
# Em produção, definir stripe_customer_id no user após checkout

# E-mail (opcional; para onboarding após compra)
# EMAIL_PROVIDER_API_KEY=
