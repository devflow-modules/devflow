{
  "name": "@devflow/career-agents-mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "career-agents-mcp": "./dist/transport/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "pnpm exec tsx src/transport/stdio.ts",
    "start:dist": "node dist/transport/stdio.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devflow/career-agents": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@devflow/config": "workspace:*",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "files": ["dist", "src", "tests"]
}
