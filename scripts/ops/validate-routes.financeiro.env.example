# Copie para validate-routes.financeiro.env (recomendado gitignored local) e ajuste URLs.
# Uso:
#   set -a && source scripts/ops/validate-routes.financeiro.env && set +a
#   bash scripts/ops/validate-routes.sh
#
# Local (portal + Financeiro na mesma origem):
BASE_URL=http://localhost:3000
APP_URL=http://localhost:3000
FINANCEIRO_APP_URL=http://localhost:3000

# Auth: dashboard sem sessão deve redirecionar para este prefixo (primeiro hop)
PROTECTED_TEST_PATH=/ferramentas/financeiro/dashboard
AUTH_REDIRECT_PREFIX=http://localhost:3000/ferramentas/financeiro/auth

AUTH_EXPECT_REDIRECT=true
FAIL_FAST=true

# Bloco D / CI: rota pública 200 sem cadeia de redirect (ajuste se CDN fizer 1 hop)
# STRICT_MODE=true
# STRICT_MAX_PUBLIC_REDIRECTS=0
# Latência (GET); desligar em CI lento: PERF_CHECK=false
# PERF_MAX_FINANCEIRO_LANDING=1.5
# Saída máquina: OUTPUT_JSON=true
#
# Cadeia de redirects: falha se mais de N hops (loop / chain longa)
# MAX_REDIRECTS_ALLOWED=5
# CURL_FOLLOW_MAX=10
#
# Debug hop-a-hop (stderr)
# TRACE_REDIRECTS=true
# MAX_TRACE_HOPS=15

# Produção (hosts reais + STRICT — alinhar com workflow Validate routes post-deploy):
# BASE_URL=https://devflowlabs.com.br
# FINANCEIRO_APP_URL=https://financeiro.devflowlabs.com.br
# STRICT_MODE=true
# STRICT_MAX_PUBLIC_REDIRECTS=1
# OUTPUT_JSON=true
# PERF_MAX_FINANCEIRO_LANDING=3
# O script deduz hosts separados e testa 308 portal→app + auth no app (AUTH_REDIRECT_PREFIX no portal pode ignorar-se nesse modo).
# Se /ferramentas/financeiro/demo ainda 404 no portal: SKIP_FINANCEIRO_DEMO_CHECK=true
