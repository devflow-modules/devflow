{
  "name": "devflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma generate --schema=prisma/whatsapp.schema.prisma && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "deploy:preview": "npx vercel",
    "deploy:prod": "npx vercel --prod",
    "build:workspace": "turbo run build",
    "dev:workspace": "turbo run dev",
    "test:workspace": "turbo run test",
    "lint:workspace": "turbo run lint",
    "create-product": "node scripts/create-product.mjs"
  },
  "dependencies": {
    "@devflow/ai-core": "workspace:*",
    "@devflow/analytics-core": "workspace:*",
    "@devflow/billing-core": "workspace:*",
    "@devflow/ui": "workspace:*",
    "@devflow/whatsapp-core": "workspace:*",
    "@prisma/client": "^6.0.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/analytics": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "posthog-js": "^1.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^2.15.0",
    "resend": "^4.0.0",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.0",
    "stripe": "^17.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.0.0",
    "tailwindcss": "^4",
    "turbo": "^2.3.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "@types/bcryptjs": "^2.4.6"
  }
}
