# =========================================================
# SEGURANÇA
# =========================================================
# - NUNCA commitar .env, .env.local, .env.production
# - Rotacionar Supabase service_role se exposta
# - .env.local = dev (apenas Stripe TEST)
# - .env.production = prod (apenas Stripe LIVE)
# - Ver .env.production.example para template de deploy

# =========================================================
# GLOBAL / MONOREPO
# =========================================================
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
VERCEL_OIDC_TOKEN=

JWT_SECRET=sua_chave_super_segura_com_32_ou_mais_caracteres

# IA (opcional, compartilhado)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=220
OPENAI_TEMPERATURE=0.4
OPENAI_TIMEOUT_MS=10000
ANTHROPIC_API_KEY=

# =========================================================
# PROJETO: FINANCEIRO (apps/financeiro)
# =========================================================

# Banco — Prisma usa DATABASE_URL e DIRECT_URL (ou aliases no deploy)
FINANCEIRO_DATABASE_URL=
FINANCEIRO_DIRECT_URL=

# Supabase
NEXT_PUBLIC_FINANCEIRO_SUPABASE_URL=
NEXT_PUBLIC_FINANCEIRO_SUPABASE_ANON_KEY=
FINANCEIRO_SUPABASE_SERVICE_ROLE_KEY=

# Stripe - LIVE
FINANCEIRO_STRIPE_SECRET_KEY=
FINANCEIRO_STRIPE_WEBHOOK_SECRET=
FINANCEIRO_STRIPE_PRICE_PRO=
FINANCEIRO_STRIPE_PRICE_TEAM=

# Stripe - TEST
FINANCEIRO_STRIPE_TEST_SECRET_KEY=
FINANCEIRO_STRIPE_TEST_WEBHOOK_SECRET=
FINANCEIRO_STRIPE_TEST_PRICE_PRO=
FINANCEIRO_STRIPE_TEST_PRICE_TEAM=

# Origem pública canônica do produto Financeiro (apps/financeiro). O portal redireciona 308 as rotas operacionais /ferramentas/financeiro/* para esta URL (Bloco B/C).
# /billing e /upgrade na raiz redirecionam para {APP_URL}/billing|upgrade. Webhook Stripe só no app Financeiro.
# Em local, típico: portal :3000 e app em apps/financeiro noutra porta (ex. :3001). Mesma origem que o portal ⇒ operação na raiz fica 404.
# Ver docs/architecture/PR1-CUTOVER-FINANCEIRO-PLANO-TECNICO.md
NEXT_PUBLIC_FINANCEIRO_APP_URL=http://localhost:3001

# =========================================================
# PROJETO: WHATSAPP PLATFORM (apps/whatsapp-platform)
# =========================================================

# Banco dedicado
WHATSAPP_DATABASE_URL=
WHATSAPP_DIRECT_URL=

# Supabase dedicado
WHATSAPP_SUPABASE_URL=
WHATSAPP_SUPABASE_SERVICE_ROLE_KEY=

# URL pública — localhost em dev, https://... em produção (checkout/portal Stripe)
# Cutover: middleware 308 para UI/auth WhatsApp — ver @devflow/whatsapp-routes e CUTOVER-WHATSAPP-RUNBOOK-MAIN.md
NEXT_PUBLIC_WHATSAPP_APP_URL=http://localhost:3000

# OAuth Embedded Signup (Meta): mesma URL no login e na troca de token. Opcional em prod (default no código).
# WHATSAPP_OAUTH_REDIRECT_URI=http://localhost:3000/dashboard/whatsapp/callback

# Admin / métricas
WHATSAPP_ADMIN_METRICS_SECRET=

# Stripe - LIVE (produção)
WHATSAPP_STRIPE_SECRET_KEY=
WHATSAPP_STRIPE_WEBHOOK_SECRET=

# FIXOS — planos recorrentes
WHATSAPP_STRIPE_PRICE_STARTER=price_1TD4h2DCRYOE69AQ4QmjzrGM
WHATSAPP_STRIPE_PRICE_PRO=price_1TD4itDCRYOE69AQd1oaiV8F
WHATSAPP_STRIPE_PRICE_SCALE=price_1TD4kTDCRYOE69AQYP8pKaiz

# OVERAGE — messages (meter event: whatsapp_messages → price vinculado no Stripe)
WHATSAPP_STRIPE_METERED_PRODUCT_MESSAGES=prod_UBRusheWCSbgNs
WHATSAPP_STRIPE_METERED_PRICE_MESSAGES=price_1TD50YDCRYOE69AQUi5x3TFf

# OVERAGE — AI (meter event: ai_usage → price vinculado no Stripe)
WHATSAPP_STRIPE_METERED_PRODUCT_AI=prod_UBRxA6RCPfFmTr
WHATSAPP_STRIPE_METERED_PRICE_AI=price_1TD540DCRYOE69AQnSbivxDS

# Stripe - TEST (dev) — use APENAS estas em .env.local
WHATSAPP_STRIPE_TEST_SECRET_KEY=
WHATSAPP_STRIPE_TEST_WEBHOOK_SECRET=
WHATSAPP_STRIPE_TEST_PRICE_STARTER=
WHATSAPP_STRIPE_TEST_PRICE_PRO=
WHATSAPP_STRIPE_TEST_PRICE_SCALE=

# Billing — ativar para monetização
BILLING_ENFORCE_LIMITS=true
BILLING_PRICE_MESSAGE_BRL=0.03
BILLING_PRICE_AI_BRL=0.09

# =========================================================
# WHATSAPP CLOUD API (Meta) — site / webhook / robô
# =========================================================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_DEMO_MODE=false

# Site — botões wa.me (obrigatório em produção para abrir o WhatsApp; se vazio, CTAs usam mailto)
NEXT_PUBLIC_WHATSAPP_NUMBER=5513999999999
NEXT_PUBLIC_WHATSAPP_DEFAULT_TEXT=Olá, gostaria de mais informações.
# Fallback quando NEXT_PUBLIC_WHATSAPP_NUMBER não está definido
NEXT_PUBLIC_CONTACT_EMAIL=contato@devflowlabs.com.br

# Meta — onboarding Cloud API (admin)
META_SYSTEM_USER_TOKEN=
META_WHATSAPP_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_BUSINESS_ID=
META_APP_ID=
META_APP_SECRET=
# Config ID do Embedded Signup — Meta Business Suite → WhatsApp Manager → Embedded Signup
META_EMBEDDED_SIGNUP_CONFIG_ID=
ADMIN_WHATSAPP_ONBOARDING_SECRET=

# Home — micro prova social
NEXT_PUBLIC_PROOF_USERS=
NEXT_PUBLIC_PROOF_OPS=

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# =========================================================
# LEGADO / COMPATIBILIDADE
# =========================================================
# Alguns apps aceitam fallback para variáveis sem prefixo.
# Ex.: STRIPE_SECRET_KEY → fallback se WHATSAPP_STRIPE_SECRET_KEY ausente
# No deploy por app, prefira injetar apenas o namespace do produto.
