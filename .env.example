# WhatsApp (site - botões wa.me)
NEXT_PUBLIC_WHATSAPP_NUMBER=5513999999999
NEXT_PUBLIC_WHATSAPP_DEFAULT_TEXT=Olá, gostaria de mais informações.

# WhatsApp Cloud API (webhook / robô)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=devflow_verify_123
WHATSAPP_DEMO_MODE=false

# Home — micro prova social (Hero). Ex.: 2500 e 520000
NEXT_PUBLIC_PROOF_USERS=
NEXT_PUBLIC_PROOF_OPS=

# Meta Pixel (Meta Ads)
NEXT_PUBLIC_META_PIXEL_ID=

# Financeiro (Supabase Auth + Prisma)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ou: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY= (Supabase novo)

# Prisma: runtime (pooler) + migrations (conexão direta)
# Runtime: Supavisor transaction mode 6543 — serverless/Vercel
# Migrate: conexão direta 5432 — prisma migrate deploy
# Senha com @ → %40, # → %23, etc.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Billing / Stripe (checkout + webhooks + Customer Portal)
# Em produção: usa STRIPE_SECRET_KEY (sk_live_...)
# Em desenvolvimento: usa STRIPE_TEST_SECRET_KEY (sk_test_...) se disponível
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_TEST_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs live (produção)
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx
# Price IDs de teste — se NODE_ENV !== production, usar os de teste
STRIPE_TEST_PRICE_PRO=price_xxx
STRIPE_TEST_PRICE_TEAM=price_xxx

# URL pública da aplicação — usada para montar returnUrl do Customer Portal e successUrl do Checkout
# Ex.: https://devflow.com.br em produção, http://localhost:3000 em dev (pode ser omitido em dev)
NEXT_PUBLIC_APP_URL=https://devflow.com.br
