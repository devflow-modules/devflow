# =============================================================================
# DevFlow monorepo — .gitignore
# =============================================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js (todas as apps) ---
.next/
out/

# --- Build / production ---
build/
dist/
*.tsbuildinfo
next-env.d.ts

# --- Environment (secrets) ---
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --- Vercel ---
.vercel

# --- Turbo ---
.turbo

# --- Testing / coverage ---
coverage/
.nyc_output/
*.lcov

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs / debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Misc ---
*.pem
*.key
.cache/

# --- Prisma (gerados) ---
# prisma/migrations mantidas; .env ignorado acima
# Cliente gerado — regerar: prisma generate / pnpm build (root)
**/src/generated/prisma-whatsapp/
